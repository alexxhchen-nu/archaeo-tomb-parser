{
	"name": "obsidian-archaeo-tombs",
	"version": "1.0.0",
	"description": "Obsidian plugin for parsing Chinese archaeological tomb reports",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": ["obsidian", "archaeology", "tomb", "chinese", "parser"],
	"author": "Xiaohan Chen",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.21.0",
		"obsidian": "latest",
		"tslib": "^2.6.0",
		"typescript": "^5.4.0"
	}
}
